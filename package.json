{
  "name": "naver-commerce-mcp",
  "version": "1.2.1",
  "description": "A security-conscious MCP server for the NAVER Commerce API",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "naver-commerce-mcp": "dist/src/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "test": "npm run build && node --test dist/test/*.test.js",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.12"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "bcryptjs": "3.0.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.15.30",
    "tsx": "4.22.4",
    "typescript": "5.8.3"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "naver",
    "commerce",
    "smartstore",
    "smart-store"
  ],
  "license": "MIT"
}
