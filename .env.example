# Required: credentials issued by NAVER Commerce API Center.
NAVER_COMMERCE_CLIENT_ID=
NAVER_COMMERCE_CLIENT_SECRET=

# SELF: access the application's own resources.
# SELLER: access a related seller resource; account ID is then required.
NAVER_COMMERCE_TOKEN_TYPE=SELF
NAVER_COMMERCE_ACCOUNT_ID=

# Safe by default. Mutation tools remain blocked unless explicitly enabled.
NAVER_COMMERCE_ALLOW_MUTATIONS=false

# Operational settings.
NAVER_COMMERCE_TIMEOUT_MS=30000
NAVER_COMMERCE_MAX_RETRIES=2
NAVER_COMMERCE_TOKEN_REFRESH_MARGIN_MS=300000
NAVER_COMMERCE_CLOCK_SKEW_MS=0

# Do not change in normal operation. This exists mainly for controlled testing.
NAVER_COMMERCE_BASE_URL=https://api.commerce.naver.com/external
